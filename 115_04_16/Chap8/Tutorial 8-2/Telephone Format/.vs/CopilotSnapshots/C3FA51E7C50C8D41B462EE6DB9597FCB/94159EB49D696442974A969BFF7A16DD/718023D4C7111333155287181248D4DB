        // IsValidNumber 方法接受一個字串參數
        // 若該字串僅包含 10 個數字字元則回傳 true，否則回傳 false
        private bool IsValidNumber(string str)
        {
            if (str.Length != 10)
            {
                return false;
            }

            foreach (char c in str)
            {
                if (!char.IsDigit(c))
                {
                    return false;
                }
            }

            return true;
        }

